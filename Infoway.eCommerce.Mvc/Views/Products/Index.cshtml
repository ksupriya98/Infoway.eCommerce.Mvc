@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products List!";
}

<h1 class="text-center fw-bold mb-1">@ViewData["PageTitle"]</h1>
<p class="text-center text-muted mb-4">Handpicked styles from the brands you love.</p>

@if (Model.Count() > 0)
{
    <div class="row g-4">
        @foreach (Product product in Model)
        {
            var finalPrice = product.UnitPrice - (product.UnitPrice * product.Discount / 100);
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card product-card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="product-img-wrap">
                        @if (product.Discount > 0)
                        {
                            <span class="badge bg-danger discount-badge">-@product.Discount%</span>
                        }
                        <img src="@Url.Content(product.Picture)" class="product-img" alt="@product.ProductName">
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate mb-1">@product.ProductName</h5>
                        <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                        <div class="mb-3">
                            <span class="fw-bold fs-5 text-success">&#8377;@finalPrice.ToString("N0")</span>
                            @if (product.Discount > 0)
                            {
                                <span class="text-muted text-decoration-line-through ms-2 small">&#8377;@product.UnitPrice.ToString("N0")</span>
                            }
                        </div>
                        <div class="d-flex gap-2 mt-auto">
                            <a class="btn btn-outline-primary btn-sm flex-grow-1" asp-action="Details" asp-route-id="@product.ProductId">Details</a>
                            <form asp-controller="Carts" asp-action="AddToCart" method="post" class="flex-grow-1 m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.ProductId" />
                                <button type="submit" class="btn btn-success btn-sm w-100">Add To Cart</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">No Products Available under this Category!</div>
}
