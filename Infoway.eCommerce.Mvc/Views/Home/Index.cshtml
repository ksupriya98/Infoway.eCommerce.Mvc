@{
    ViewData["Title"] = "Home Page";

    var slides = new[]
    {
        new { Img = "~/Images/nike_soc_m_1.jpeg", Title = "Step Into Performance", Caption = "Premium sports shoes built for every move." },
        new { Img = "~/Images/adidas_soc_m_1.jpeg", Title = "Run The City", Caption = "Lightweight comfort that keeps up with you." },
        new { Img = "~/Images/woodland_b_m_1.jpeg", Title = "Built For The Outdoors", Caption = "Rugged boots for every adventure." },
        new { Img = "~/Images/campus_c_w_3.jpeg", Title = "Casual, Redefined", Caption = "Everyday styles for everyone." }
    };
}

<div id="heroCarousel" class="carousel slide shadow-lg rounded-4 overflow-hidden mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        @for (int i = 0; i < slides.Length; i++)
        {
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i"
                    class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"
                    aria-label="Slide @(i + 1)"></button>
        }
    </div>
    <div class="carousel-inner">
        @for (int i = 0; i < slides.Length; i++)
        {
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <div class="hero-slide" style="background-image: url('@Url.Content(slides[i].Img)');"></div>
                <div class="carousel-caption text-start">
                    <h2 class="display-5 fw-bold">@slides[i].Title</h2>
                    <p class="lead d-none d-md-block">@slides[i].Caption</p>
                    <a class="btn btn-light btn-lg fw-semibold" asp-controller="Products" asp-action="Index">Shop Now</a>
                </div>
            </div>
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold">Welcome to Infoway Shoes</h1>
    <p class="lead text-muted">Discover the latest collection from your favourite brands.</p>
    <a class="btn btn-primary btn-lg" asp-controller="Categories" asp-action="Index">Browse Categories</a>
    <a class="btn btn-outline-primary btn-lg" asp-controller="Products" asp-action="Index">All Products</a>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="feature-card text-center p-4 h-100 rounded-4 bg-body-tertiary shadow-sm">
            <div class="feature-icon">&#128666;</div>
            <h5 class="fw-bold">Free Shipping</h5>
            <p class="text-muted mb-0">On all orders, delivered to your doorstep.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card text-center p-4 h-100 rounded-4 bg-body-tertiary shadow-sm">
            <div class="feature-icon">&#128176;</div>
            <h5 class="fw-bold">Easy Returns</h5>
            <p class="text-muted mb-0">15-day hassle-free return policy.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card text-center p-4 h-100 rounded-4 bg-body-tertiary shadow-sm">
            <div class="feature-icon">&#10024;</div>
            <h5 class="fw-bold">Genuine Brands</h5>
            <p class="text-muted mb-0">100% authentic products, guaranteed.</p>
        </div>
    </div>
</div>
