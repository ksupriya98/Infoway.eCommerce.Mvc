@model List<CartItem>
@{
    ViewData["Title"] = "Order Placed";
    var invoice = ViewBag.Invoice as Invoice;
    decimal Discounted(Product p) => p.UnitPrice - (p.UnitPrice * p.Discount / 100);
    var grandTotal = Model.Sum(i => Discounted(i.Product) * i.Quantity);
    var totalItems = Model.Sum(i => i.Quantity);
}

<div class="text-center my-5">
    <div class="success-check mx-auto mb-3">&#10003;</div>
    <h1 class="fw-bold text-success">Payment Successful</h1>
    <p class="lead text-muted mb-1">Your order has been placed successfully.</p>
    @if (invoice != null)
    {
        <p class="mb-0">Order <span class="fw-bold">#@invoice.InvoiceId</span> &middot; @invoice.InvoiceDate.ToString("dd MMM yyyy, hh:mm tt")</p>
    }
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mx-auto" style="max-width: 720px;">
    <div class="card-header bg-success-subtle fw-semibold">Order Summary</div>
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Product</th>
                <th class="text-center">Qty</th>
                <th class="text-end">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var price = Discounted(item.Product);
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="@Url.Content(item.Product.Picture)" alt="@item.Product.ProductName"
                                 style="width:52px;height:52px;object-fit:cover;border-radius:.5rem;background:#f6f7f9;">
                            <span class="fw-semibold">@item.Product.ProductName</span>
                        </div>
                    </td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end fw-semibold">&#8377;@((price * item.Quantity).ToString("N0"))</td>
                </tr>
            }
        </tbody>
        <tfoot class="table-light">
            <tr>
                <th class="text-end">Total Paid</th>
                <th class="text-center">@totalItems</th>
                <th class="text-end text-success">&#8377;@grandTotal.ToString("N0")</th>
            </tr>
        </tfoot>
    </table>
</div>

<div class="text-center mt-4">
    <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Index">Continue Shopping</a>
</div>
