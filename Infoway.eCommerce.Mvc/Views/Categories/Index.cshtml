@model List<Category>
@{
    ViewData["Title"] = "Categories List";

    string CategoryImage(string name)
    {
        name = (name ?? "").ToLowerInvariant();
        if (name.Contains("sport")) return "~/Images/nike_soc_m_1.jpeg";
        if (name.Contains("casual")) return "~/Images/campus_c_w_2.jpeg";
        if (name.Contains("boot")) return "~/Images/woodland_b_m_1.jpeg";
        if (name.Contains("life")) return "~/Images/nike_l_m_1.jpg";
        return "~/Images/noimage.png";
    }
}

<p class="text-center text-muted mb-4 mt-3">Browse our collection by category.</p>

<div class="row g-4">
    @foreach (Category cat in Model)
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card category-card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="category-img" style="background-image: url('@Url.Content(CategoryImage(cat.CategoryName))');">
                    <span class="category-overlay-title">@cat.CategoryName</span>
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="card-text text-muted small flex-grow-1">@cat.Description</p>
                    <a class="btn btn-primary mt-auto" asp-controller="Products" asp-action="CatWiseProducts" asp-route-categoryId="@cat.CategoryId">
                        Show Products
                    </a>
                </div>
            </div>
        </div>
    }
</div>
